{
  "name": "fairplay-dev-tests",
  "version": "1.0.0",
  "description": "Playwright E2E tests for FairPlay DEV environment",
  "scripts": {
    "test": "npx playwright test",
    "test:login": "npx playwright test tests/auth/",
    "test:products": "npx playwright test tests/products/",
    "test:purchase": "npx playwright test tests/purchase/",
    "test:account": "npx playwright test tests/account/",
    "test:referral": "npx playwright test tests/referral/",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report",
    "clean": "rm -rf playwright-report test-results .auth"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
